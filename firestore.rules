rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: orders
    // Document ID: auto-generated
    // Fields:
    //   - nickname: string (required, 1-50 chars)
    //   - items: list (required, 1-20 items)
    //   - comment: string (optional, 0-200 chars)
    //   - arrivalTime: string (required, HH:mm format)
    //   - timestamp: number (required, epoch ms)
    //   - status: string (required, enum: ['pending', 'completed', 'cancelled'])
    //   - uid: string (required, immutable, matches creator's UID)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "jibega218@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidOrder(data) {
      return data.nickname is string && data.nickname.size() > 0 && data.nickname.size() <= 50 &&
             data.items is list && data.items.size() > 0 && data.items.size() <= 20 &&
             (!('comment' in data) || (data.comment is string && data.comment.size() <= 200)) &&
             data.arrivalTime is string && data.arrivalTime.matches("^\\d{2}:\\d{2}$") &&
             data.timestamp is number &&
             data.status in ['pending', 'completed', 'cancelled'] &&
             data.uid is string && (isAuthenticated() ? data.uid == request.auth.uid : data.uid == 'anonymous');
    }

    function isValidStatusUpdate(oldData, newData) {
      // Only allow status to be changed
      return newData.diff(oldData).affectedKeys().hasOnly(['status']) &&
             newData.status in ['pending', 'completed', 'cancelled'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /orders/{orderId} {
      // Public access for everything to restore original behavior
      allow read, create, update, delete: if true;
    }
  }
}
